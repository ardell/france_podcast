# Secrets — never commit
.envrc

# Local build/scratch
episodes/audio/*.aiff
episodes/samples/
# Cached intro/outro TTS renders (avoids re-billing identical speech).
assets/.tts-cache/

# macOS
.DS_Store

# Local rendered audio is a BUILD ARTIFACT — not tracked in git. The episode
# SCRIPTS (episodes/text/*.txt) are the source of truth; regenerate audio
# anytime with bin/build.sh. Keeping these working copies out of git avoids bloat.
episodes/audio/*.mp3
episodes/bodies/*.mp3

# EXCEPTION: the bumper music is a source asset the build needs — keep it.
!assets/bumper-music.mp3
!assets/bumper-music-full.mp3

# NOTE: docs/episodes/*.mp3 IS tracked on purpose — docs/ is the GitHub Pages
# publish root, and those mp3s are the audio the public feed serves (the feed's
# <enclosure> URLs point at ardell.github.io/.../episodes/*.mp3). Do NOT ignore
# them, or every episode 404s. bin/publish_feed.sh copies them in before commit.

# Claude Code harness internals
.claude/
