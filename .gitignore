# Secrets — never commit
.envrc

# Local build/scratch
episodes/audio/*.aiff
episodes/samples/
# Cached intro/outro TTS renders (avoids re-billing identical speech).
assets/.tts-cache/

# macOS
.DS_Store

# Rendered audio is a BUILD ARTIFACT — not tracked in git. Episodes are hosted
# on Dropbox (see bin/publish.sh), not from the repo. The episode SCRIPTS
# (episodes/text/*.txt) are the source of truth and ARE tracked; regenerate
# audio anytime with bin/build.sh. Keeping mp3s out of git avoids repo bloat.
episodes/audio/*.mp3
episodes/bodies/*.mp3
docs/episodes/*.mp3

# EXCEPTION: the bumper music is a source asset the build needs — keep it.
!assets/bumper-music.mp3
!assets/bumper-music-full.mp3

# The rest of docs/ (feed.xml, cover.jpg, docs/episodes/*.html) IS tracked —
# GitHub Pages serves the site/feed; only the audio moves to Dropbox.

# Claude Code harness internals
.claude/
